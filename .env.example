# Server — for local sandbox use NODE_ENV=development and: npm run dev
NODE_ENV=development
PORT=3000

# SQLite database (mounted as a volume in Docker)
DATABASE_PATH=data/wiring.sqlite

# DTC / OBD dictionary (from scripts/extract_vida_dtc.py)
DTC_DATABASE_PATH=data/dtc.sqlite

# EWD indexes (device_index.json, svg_desc_index.json, …)
EWD_DATA_DIR=data/ewd

# Raw Capital package (default: data/ewd/ewd_source/39363002/1/2 — local mirror of E:\manual)
# EWD_SOURCE_DIR=data/ewd/ewd_source/39363002/1/2

# PDF manuals root (default locally: data/ewd, where Электросхемы XC70.pdf is mirrored)
MANUAL_DIR=data/ewd

# Vite client build output (usually leave default)
CLIENT_DIST=client/dist

# Admin (/admin)
ADMIN_PASSWORD=
ADMIN_SECRET=

# Tickets → moderator email (default elzidevelop@gmail.com)
MODERATOR_EMAIL=elzidevelop@gmail.com

# SMTP (required for outbound mail). Gmail: App Password, port 587, SECURE=false.
# On VPS put these in /opt/ewd-app/.env — deploy.sh / fixdb.sh pass them into the container.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=elzidevelop@gmail.com
SMTP_PASS=
SMTP_FROM=elzidevelop@gmail.com

