# Server
NODE_ENV=production
PORT=3000

# SQLite database (mounted as a volume in Docker)
DATABASE_PATH=data/wiring.sqlite

# EWD indexes (device_index.json, svg_desc_index.json, …)
EWD_DATA_DIR=data/ewd

# Optional: override absolute path to raw EWD SVG/source tree
# EWD_SOURCE_DIR=/data/ewd_source

# PDF manuals root (pinout tables)
MANUAL_DIR=/data/manual

# Vite client build output (usually leave default)
CLIENT_DIST=client/dist

# Admin (/admin)
ADMIN_PASSWORD=
ADMIN_SECRET=

# Tickets → moderator email (default elzidevelo@gmail.com)
MODERATOR_EMAIL=elzidevelo@gmail.com

# SMTP (required for outbound mail). Gmail: App Password, port 587, SECURE=false.
# On VPS put these in /opt/ewd-app/.env — deploy.sh / fixdb.sh pass them into the container.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=elzidevelo@gmail.com
SMTP_PASS=
SMTP_FROM=elzidevelo@gmail.com

