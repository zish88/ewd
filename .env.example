# Server
NODE_ENV=production
PORT=3000

# SQLite database (mounted as a volume in Docker)
DATABASE_PATH=data/wiring.sqlite

# EWD indexes (device_index.json, svg_desc_index.json, …)
EWD_DATA_DIR=data/ewd

# Optional: override absolute path to raw EWD SVG/source tree
# EWD_SOURCE_DIR=/data/ewd_source

# PDF manuals root (pinout tables)
MANUAL_DIR=/data/manual

# Vite client build output (usually leave default)
CLIENT_DIST=client/dist

# SMTP (optional — tickets)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
ADMIN_PASSWORD=
